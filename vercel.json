{
  "version": 2,
  "builds": [
    {
      "src": "api/transform.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/transform",
      "dest": "/api/transform.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
